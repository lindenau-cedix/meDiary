# Port für die HTTP-API
PORT=4000

# Pfad zur SQLite-Datenbankdatei (relativ zum server/ Ordner oder absolut)
DB_PATH=./data/mediary.db

# Pfad zur DEFAULTS.md (Standard-Notizen/-Mengen pro Substanz).
# Standard: Datei im Projekt-Wurzelverzeichnis (eine Ebene über server/).
DEFAULTS_PATH=../DEFAULTS.md

# Optional: gebautes Frontend ausliefern (Pfad zum web/dist Ordner). Leer lassen = aus.
WEB_DIST=
