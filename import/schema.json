{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MedicationLogEntry",
  "type": "object",
  "required": ["event_id", "timestamp", "consumption_day", "event_type", "group_id", "source_message", "substances", "created_at"],
  "properties": {
    "event_id": {"type": "string"},
    "timestamp": {"type": "string"},
    "consumption_day": {"type": "string"},
    "event_type": {"type": "string", "enum": ["plan_change", "planned_intake", "acute_intake", "missing_planned_intake", "correction"]},
    "group_id": {"type": "string"},
    "source_message": {"type": "string"},
    "substances": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {"type": "string"},
          "dose": {"type": ["number", "string", "null"]},
          "unit": {"type": ["string", "null"]},
          "notes": {"type": ["string", "null"]}
        },
        "additionalProperties": true
      }
    },
    "plan_context": {"type": ["object", "null"]},
    "classification_reason": {"type": ["string", "null"]},
    "effective_from": {"type": ["string", "null"]},
    "effective_until": {"type": ["string", "null"]},
    "correction_of": {"type": ["string", "null"]},
    "confidence": {"type": ["number", "null"]},
    "tags": {"type": ["array", "null"]},
    "created_at": {"type": "string"}
  },
  "additionalProperties": true
}
